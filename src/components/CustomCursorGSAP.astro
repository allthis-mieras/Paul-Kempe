<div class="cursor">
  <span class="cursor-text">
    <img src="/icon-on.svg" alt="Mute Icon" width="32" class="cursor-icon" />
  </span>
</div>
<style>
  .cursor {
    position: fixed;
    width: 1.5rem;
    height: 1.5rem;
    top: 0;
    left: 0;
    background: transparent;
    border-radius: 50%;
    pointer-events: none;
    z-index: 2000;
    opacity: 0.7;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--font-color, red);
  }

  .cursor.grow {
    scale: 1.5; /* Maak de cursor groter */
    background-color: transparent; /* Verwijder de rode achtergrondkleur */
  }

  .cursor-icon {
    width: 60%;
    height: 60%;
    display: none; /* Verberg standaard het icoon */
    transition: opacity 0.3s ease;
  }

  .cursor-icon[src] {
    display: block; /* Toon de afbeelding als de src is ingesteld */
  }

  .cursor.hide {
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .cursor-text img {
    width: 100%;
    height: 100%;
    display: block;
    fill: currentColor;
  }

  .cursor-text img[src=""] {
    display: none; /* Verberg het icoon als src leeg is */
  }

  @media (hover: none) and (pointer: coarse) {
    .cursor {
      display: none;
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  let cursor: HTMLElement | null = null;
  let cursorIcon: HTMLImageElement | null = null;
  let xTo: ((value: number) => void) | null = null;
  let yTo: ((value: number) => void) | null = null;
  let mouseMoveHandler: ((e: MouseEvent) => void) | null = null;

  const initializeCursor = () => {
    cursor = document.querySelector<HTMLElement>(".cursor");
    cursorIcon = document.querySelector<HTMLImageElement>(".cursor-icon");

    if (!cursor) return;

    // Remove old event listeners if they exist
    if (mouseMoveHandler) {
      window.removeEventListener("mousemove", mouseMoveHandler);
    }

    gsap.set(cursor, {
      xPercent: -50,
      yPercent: -50,
    });

    xTo = gsap.quickTo(cursor, "x", { duration: 0.6, ease: "power3" });
    yTo = gsap.quickTo(cursor, "y", { duration: 0.6, ease: "power3" });

    mouseMoveHandler = (e: MouseEvent) => {
      if (xTo && yTo) {
        xTo(e.clientX);
        yTo(e.clientY);
      }
    };

    window.addEventListener("mousemove", mouseMoveHandler);

    document.addEventListener("mouseleave", () => {
      if (cursor) {
        gsap.to(cursor, { duration: 0.7, opacity: 0 });
      }
    });

    document.addEventListener("mouseenter", () => {
      if (cursor) {
        gsap.to(cursor, { duration: 0.7, opacity: 0.7 });
      }
    });

    // Link hover effects
    document.querySelectorAll("a").forEach((link) => {
      link.addEventListener("mousemove", () => {
        if (cursor) {
          gsap.to(cursor, {
            scale: 1.5,
            autoAlpha: 1,
            duration: 0.1,
          });
        }
      });

      link.addEventListener("mouseleave", () => {
        if (cursor) {
          gsap.to(cursor, {
            scale: 1,
            autoAlpha: 0.7,
            duration: 0.3,
          });
        }
      });
    });

    // Video hover effects - find video dynamically
    const video = document.querySelector<HTMLVideoElement>("#video");
    if (video) {
      video.addEventListener("mousemove", () => {
        if (cursor) {
          gsap.to(cursor, {
            scale: 2.5,
            autoAlpha: 1,
            backgroundColor: "transparent",
            duration: 0.1,
          });
          updateCursorIcon(video);
        }
      });

      video.addEventListener("mouseleave", () => {
        if (cursor) {
          gsap.to(cursor, {
            scale: 1,
            autoAlpha: 0.7,
            backgroundColor: "red",
            duration: 0.3,
          });
        }
        if (cursorIcon) {
          cursorIcon.setAttribute("src", "");
          cursorIcon.style.display = "none";
        }
      });
    }

    function updateCursorIcon(video: HTMLVideoElement) {
      if (!cursorIcon) return;
      if (video.muted) {
        cursorIcon.setAttribute("src", "/icon-on.svg");
        cursorIcon.style.display = "block";
      } else {
        cursorIcon.setAttribute("src", "/icon-mute.svg");
        cursorIcon.style.display = "block";
      }
    }
  };

  // Initialize on page load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeCursor);
  } else {
    initializeCursor();
  }

  // Re-initialize on view transitions (Astro 5)
  document.addEventListener("astro:page-load", initializeCursor);
  document.addEventListener("astro:after-swap", initializeCursor);
</script>
