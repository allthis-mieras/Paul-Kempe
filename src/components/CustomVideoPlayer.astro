---
import { urlForImage } from "../sanity/lib/urlForImage";
const {
  class: className,
  videoUrlDesktop,
  videoUrlMobile,
  posterImage,
  aspectRatio,
  ...rest
} = Astro.props;
---

<div data-cursor="video">
  <video
    id="video"
    muted
    autoplay
    loop
    playsinline
    style={`--aspect-ratio: ${aspectRatio}`}
    class={className}
    poster={urlForImage(posterImage).url()}
    data-cursor="video"
    data-desktop-vid={videoUrlDesktop}
    data-mobile-vid={videoUrlMobile}
    {...rest}
  >
    Your browser does not support the video tag.
  </video>
  <button id="audio-control" class="button muted">
    <img
      src="/icon-on.svg"
      alt="Audio Control Icon"
      class="audio-control-icon"
    />
  </button>
</div>

<style lang="scss">
  .responsive-video {
    display: flex;
    flex-direction: column;
  }

  video {
    aspect-ratio: var(--aspect-ratio);
    width: 100%;
    height: auto;

    &[poster] {
      object-fit: cover;
      width: 100%;
      height: 100%;
    }
  }

  .desktop-video {
    display: none;
    aspect-ratio: 16 / 9;
  }

  .mobile-video {
    display: block;
    aspect-ratio: 9 / 16;
  }

  .button {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    z-index: 10;
  }

  .audio-control-icon {
    width: 1rem;
    height: auto;
    transition: opacity 0.3s ease;
  }

  @media (min-width: 768px) {
    .desktop-video {
      display: block;
    }
    .mobile-video {
      display: none;
    }

    .button {
      display: none;
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  function initializeVideoPlayer() {
    const videos = document.querySelectorAll<HTMLVideoElement>(".video");
    const audioControlButton = document.getElementById("audio-control");
    const audioControlIcon = document.querySelector<HTMLImageElement>(".audio-control-icon");
    const cursorIcon = document.querySelector<HTMLImageElement>(".cursor-icon");

    // Functie om de video te muten of unmute
    function toggleMute(video: HTMLVideoElement) {
      if (!video) return;
      video.muted = !video.muted;
      updateButtonIcon(video);
      updateCursorIcon(video);
    }

    // Update de mute/unmute iconen van de button
    function updateButtonIcon(video: HTMLVideoElement) {
      if (!audioControlIcon) return;
      audioControlIcon.src = video.muted ? "/icon-on.svg" : "/icon-mute.svg";
    }

    // Update de mute/unmute iconen van de cursor
    function updateCursorIcon(video: HTMLVideoElement) {
      if (!cursorIcon) return;
      cursorIcon.src = video.muted ? "/icon-on.svg" : "/icon-mute.svg";
    }

    // Video source toevoegen aan video tag
    function addSourceToVideo(element: HTMLVideoElement, src: string) {
      // Verwijder bestaande sources eerst
      const existingSources = element.querySelectorAll("source");
      existingSources.forEach((source) => source.remove());

      const source = document.createElement("source");
      source.src = src;
      source.type = "video/mp4";
      element.appendChild(source);
      
      // Laad en speel de video af
      element.load();
      element.play().catch((error) => {
        console.log("Video autoplay blocked:", error);
      });
    }

    // Bepaal of desktop of mobiele video wordt geladen
    function whichSizeVideo(element: HTMLVideoElement) {
      const windowWidth = window.innerWidth || document.documentElement.clientWidth;
      const desktopVid = element.dataset.desktopVid;
      const mobileVid = element.dataset.mobileVid;
      
      if (windowWidth > 1200 && desktopVid) {
        addSourceToVideo(element, desktopVid);
      } else if (mobileVid) {
        addSourceToVideo(element, mobileVid);
      }
    }

    // Initialiseer video size en events
    videos.forEach((video) => {
      // Voeg source toe
      whichSizeVideo(video);

      // Voeg click-event toe aan video
      video.addEventListener("click", function (e) {
        e.preventDefault();
        toggleMute(video);
      });

      // Cursor interactie
      video.addEventListener("mousemove", () => {
        const cursor = document.querySelector<HTMLElement>(".cursor");
        if (cursor && typeof gsap !== "undefined") {
          gsap.to(cursor, {
            scale: 3.5,
            autoAlpha: 0.9,
            duration: 0.1,
          });
          updateCursorIcon(video);
        }
      });

      video.addEventListener("mouseleave", () => {
        const cursor = document.querySelector<HTMLElement>(".cursor");
        const cursorIcon = document.querySelector<HTMLImageElement>(".cursor-icon");

        if (cursor && typeof gsap !== "undefined") {
          gsap.to(cursor, {
            scale: 1,
            backgroundColor: "red",
            autoAlpha: 0.7,
            duration: 0.3,
          });
        }

        if (cursorIcon) {
          cursorIcon.setAttribute("src", "");
          cursorIcon.style.display = "none";
        }
      });
    });

    // Voeg click-event toe aan de "audio-control" button
    if (audioControlButton) {
      audioControlButton.addEventListener("click", function (e) {
        e.preventDefault();
        videos.forEach((video) => toggleMute(video));
      });
    }
  }

  // Initialize on page load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeVideoPlayer);
  } else {
    initializeVideoPlayer();
  }

  // Re-initialize on view transitions (Astro 5)
  document.addEventListener("astro:page-load", initializeVideoPlayer);
  document.addEventListener("astro:after-swap", initializeVideoPlayer);
</script>
